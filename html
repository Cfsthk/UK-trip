    </div>

    <footer class="max-w-screen-xl mx-auto px-6 py-8 text-center text-xs text-slate-500 border-t">
        <p>Prices and opening times are approximate for 2026 and subject to change. Always verify on official websites before booking. This itinerary is a personal planning tool created for Charles (方貴瀚).</p>
        <p class="mt-1">Safe travels • Enjoy the heritage, the magic, and the landscapes! ✨</p>
    </footer>

    <script>
        // Tailwind script
        function initializeTailwind() {
            document.documentElement.style.setProperty('--accent', '#b45309');
        }
        
        // Day switching with active tab highlighting
        function switchDay(dayId) {
            // Hide all panels
            document.querySelectorAll('.day-panel').forEach(panel => {
                panel.classList.add('hidden');
                panel.classList.remove('block');
            });
            
            // Show target
            const target = document.getElementById(dayId);
            if (target) {
                target.classList.remove('hidden');
                target.classList.add('block');
            }
            
            // Update active tab styles
            document.querySelectorAll('.nav-tab').forEach(tab => {
                tab.classList.remove('active', 'bg-blue-800', 'text-white', 'border-blue-800');
                tab.classList.add('bg-white', 'border-slate-200', 'text-slate-700');
                
                if (tab.id === 'tab-' + dayId) {
                    tab.classList.add('active', 'bg-blue-800', 'text-white', 'border-blue-800');
                    tab.classList.remove('bg-white', 'border-slate-200', 'text-slate-700');
                }
            });
            
            // Smooth scroll to top of content
            window.scrollTo({ top: 180, behavior: 'smooth' });
        }
        
        // Keyboard support for tabs
        function addKeyboardSupport() {
            const tabs = document.querySelectorAll('.nav-tab');
            tabs.forEach((tab, index) => {
                tab.setAttribute('tabindex', '0');
                tab.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter' || e.key === ' ') {
                        e.preventDefault();
                        const dayId = tab.id.replace('tab-', '');
                        switchDay(dayId);
                    }
                    
                    // Arrow key navigation
                    if (e.key === 'ArrowRight') {
                        const next = tabs[(index + 1) % tabs.length];
                        next.focus();
                        const nextDay = next.id.replace('tab-', '');
                        switchDay(nextDay);
                    }
                    if (e.key === 'ArrowLeft') {
                        const prev = tabs[(index - 1 + tabs.length) % tabs.length];
                        prev.focus();
                        const prevDay = prev.id.replace('tab-', '');
                        switchDay(prevDay);
                    }
                });
            });
        }
        
        // Initialize everything
        function init() {
            initializeTailwind();
            addKeyboardSupport();
            
            // Set initial active tab styling properly
            const initialTab = document.getElementById('tab-day4');
            if (initialTab) {
                initialTab.classList.add('active', 'bg-blue-800', 'text-white', 'border-blue-800');
            }
            
            // Show day4 by default (already has active class in HTML)
            const day4 = document.getElementById('day4');
            if (day4) day4.classList.remove('hidden');
            
            // Optional: Add subtle animation to cards on load
            setTimeout(() => {
                document.querySelectorAll('.itinerary-card').forEach((card, i) => {
                    card.style.opacity = '0';
                    card.style.transform = 'translateY(10px)';
                    setTimeout(() => {
                        card.style.transition = 'all 0.4s cubic-bezier(0.4, 0.0, 0.2, 1)';
                        card.style.transitionDelay = (i * 40) + 'ms';
                        card.style.opacity = '1';
                        card.style.transform = 'translateY(0)';
                    }, 50);
                });
            }, 300);
            
            // Console hint for developer
            console.log('%c[Itinerary] Redesigned premium HTML ready. All interactive tabs and content loaded.', 'color:#64748b');
        }
        
        // Boot
        window.onload = init;
        
        // Expose switchDay for debugging if needed
        window.switchDay = switchDay;
    </script>
</body>
